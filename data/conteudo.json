{
  "disciplinas": {
    "matematica": {
      "nome": "Matemática",
      "icone": "📐",
      "cor": "#3498db",
      "descricao": "Estude matemática do zero até conceitos avançados",
      "topicos": [
        {
          "id": "numeros-naturais",
          "titulo": "Números Naturais",
          "descricao": "Compreenda os números naturais e suas propriedades",
          "conteudo": {
            "explicacao": "Os números naturais são: 0, 1, 2, 3, 4, 5, ... Eles são usados para contar e ordenar objetos.",
            "exemplos": [
              "5 maçãs",
              "10 pessoas",
              "100 reais"
            ],
            "propriedades": [
              "Fechamento: A soma de dois números naturais é sempre um número natural",
              "Comutatividade: 3 + 5 = 5 + 3",
              "Associatividade: (2 + 3) + 4 = 2 + (3 + 4)"
            ]
          }
        },
        {
          "id": "adicao-subtracao",
          "titulo": "Adição e Subtração",
          "descricao": "Aprenda as operações básicas de adição e subtração",
          "conteudo": {
            "explicacao": "Adição é juntar quantidades. Subtração é tirar uma quantidade de outra.",
            "exemplos": [
              "3 + 5 = 8 (juntamos 3 com 5)",
              "10 - 4 = 6 (tiramos 4 de 10)",
              "7 + 2 - 3 = 6"
            ],
            "propriedades": [
              "Adição é comutativa: 3 + 5 = 5 + 3",
              "Subtração não é comutativa: 5 - 3 ≠ 3 - 5",
              "O zero é o elemento neutro da adição"
            ]
          }
        },
        {
          "id": "multiplicacao-divisao",
          "titulo": "Multiplicação e Divisão",
          "descricao": "Domine as operações de multiplicação e divisão",
          "conteudo": {
            "explicacao": "Multiplicação é uma adição repetida. Divisão é repartir em partes iguais.",
            "exemplos": [
              "3 × 4 = 12 (3 grupos de 4)",
              "12 ÷ 3 = 4 (12 dividido em 3 partes)",
              "5 × 6 = 30"
            ],
            "propriedades": [
              "Multiplicação é comutativa: 3 × 4 = 4 × 3",
              "Divisão não é comutativa: 12 ÷ 3 ≠ 3 ÷ 12",
              "O um é o elemento neutro da multiplicação"
            ]
          }
        },
        {
          "id": "fracoes",
          "titulo": "Frações",
          "descricao": "Compreenda frações e operações com frações",
          "conteudo": {
            "explicacao": "Uma fração representa uma parte de um todo. É escrita como numerador/denominador.",
            "exemplos": [
              "1/2 = metade",
              "1/4 = um quarto",
              "3/4 = três quartos"
            ],
            "propriedades": [
              "Frações equivalentes: 1/2 = 2/4 = 3/6",
              "Soma: 1/2 + 1/4 = 2/4 + 1/4 = 3/4",
              "Multiplicação: 1/2 × 1/3 = 1/6"
            ]
          }
        },
        {
          "id": "numeros-decimais",
          "titulo": "Números Decimais",
          "descricao": "Trabalhe com números decimais e conversões",
          "conteudo": {
            "explicacao": "Números decimais usam a vírgula para separar a parte inteira da parte fracionária.",
            "exemplos": [
              "0,5 = 1/2",
              "0,25 = 1/4",
              "1,5 = 3/2"
            ],
            "propriedades": [
              "Conversão: 1/2 = 0,5",
              "Soma: 1,5 + 2,3 = 3,8",
              "Multiplicação: 0,5 × 2 = 1,0"
            ]
          }
        }
      ]
    },
    "biologia": {
