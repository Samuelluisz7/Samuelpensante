              "Adaptação: características que ajudam na sobrevivência",
              "Especiação: formação de novas espécies"
            ],
            "propriedades": [
              "Baseada em variação genética",
              "Luta pela sobrevivência",
              "Descendência com modificação"
            ]
          }
        }
