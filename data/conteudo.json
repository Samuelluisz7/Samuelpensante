          "id": "fotossintese",
          "titulo": "Fotossíntese",
          "descricao": "Compreenda como as plantas produzem energia",
          "conteudo": {
            "explicacao": "Fotossíntese é o processo onde as plantas convertem luz solar em energia química.",
            "exemplos": [
              "6CO₂ + 6H₂O + luz → C₆H₁₂O₆ + 6O₂",
              "Fase luminosa: ocorre nos tilacoides",
              "Fase escura: ocorre no estroma"
            ],
            "propriedades": [
              "Produz oxigênio necessário para respiração",
              "Produz glicose como fonte de energia",
              "Base da cadeia alimentar"
            ]
          }
        },
        {
          "id": "respiracao-celular",
          "titulo": "Respiração Celular",
          "descricao": "Aprenda como as células produzem energia",
          "conteudo": {
            "explicacao": "Respiração celular é o processo onde a glicose é quebrada para liberar energia.",
            "exemplos": [
              "C₆H₁₂O₆ + 6O₂ → 6CO₂ + 6H₂O + energia",
              "Glicólise: ocorre no citoplasma",
              "Ciclo de Krebs: ocorre na mitocôndria"
            ],
            "propriedades": [
              "Produz ATP (energia)",
              "Consome glicose e oxigênio",
              "Libera dióxido de carbono"
            ]
          }
        },
        {
          "id": "dna",
          "titulo": "DNA e Genética",
          "descricao": "Compreenda a hereditariedade e o DNA",
          "conteudo": {
            "explicacao": "DNA é a molécula que contém as instruções para construir e manter um organismo.",
            "exemplos": [
              "DNA tem forma de dupla hélice",
              "Genes são segmentos de DNA",
              "Cromossomos contêm muitos genes"
            ],
            "propriedades": [
              "Formado por nucleotídeos",
              "Bases: Adenina, Timina, Guanina, Citosina",
              "Replicação: cada fita serve como molde"
            ]
          }
        },
        {
          "id": "evolucao",
          "titulo": "Evolução",
          "descricao": "Entenda a teoria da evolução e seleção natural",
          "conteudo": {
            "explicacao": "Evolução é o processo de mudança dos organismos ao longo do tempo.",
            "exemplos": [
